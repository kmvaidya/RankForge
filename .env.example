# =============================================================================
# RankForge Environment Configuration
# =============================================================================
# Copy this file to .env and customize for your environment

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# For SQLite (local development without Docker):
#   DATABASE_URL=sqlite+aiosqlite:///./rankforge.db
#
# For PostgreSQL (Docker or production):
#   DATABASE_URL=postgresql+asyncpg://user:password@host:port/dbname

DATABASE_URL=sqlite+aiosqlite:///./rankforge.db

# -----------------------------------------------------------------------------
# PostgreSQL Container Settings (used by docker-compose)
# -----------------------------------------------------------------------------
POSTGRES_USER=rankforge
POSTGRES_PASSWORD=rankforge_dev
POSTGRES_DB=rankforge

# -----------------------------------------------------------------------------
# Connection Pool Configuration (PostgreSQL only, ignored for SQLite)
# -----------------------------------------------------------------------------
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# -----------------------------------------------------------------------------
# Debugging
# -----------------------------------------------------------------------------
# Enable SQL query logging (set to "true" for debugging)
DB_ECHO=false

# -----------------------------------------------------------------------------
# Docker Port Configuration
# -----------------------------------------------------------------------------
# Port mappings (host:container)
API_PORT=8000
DB_PORT=5432
