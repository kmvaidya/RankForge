# =============================================================================
# RankForge Environment Configuration
# =============================================================================
# Copy this file to .env and customize for your environment

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# For SQLite (local development without Docker):
#   DATABASE_URL=sqlite+aiosqlite:///./rankforge.db
#
# For PostgreSQL (Docker or production):
#   DATABASE_URL=postgresql+asyncpg://user:password@host:port/dbname

DATABASE_URL=sqlite+aiosqlite:///./rankforge.db

# -----------------------------------------------------------------------------
# PostgreSQL Container Settings (used by docker-compose)
# -----------------------------------------------------------------------------
POSTGRES_USER=rankforge
POSTGRES_PASSWORD=rankforge_dev
POSTGRES_DB=rankforge

# -----------------------------------------------------------------------------
# Connection Pool Configuration (PostgreSQL only, ignored for SQLite)
# -----------------------------------------------------------------------------
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# -----------------------------------------------------------------------------
# Match Corrections
# -----------------------------------------------------------------------------
# Maximum age (in days, from played_at) a match can be updated/corrected.
# 0 = unlimited (default; RankForge data is largely historical imports).
MATCH_UPDATE_MAX_AGE_DAYS=0

# -----------------------------------------------------------------------------
# Debugging
# -----------------------------------------------------------------------------
# Enable SQL query logging (set to "true" for debugging)
DB_ECHO=false

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Comma-separated origins allowed to call the API from a browser.
# Add your deployed frontend origin in production.
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:3000

# -----------------------------------------------------------------------------
# Docker Port Configuration
# -----------------------------------------------------------------------------
# Port mappings (host:container)
API_PORT=8000
DB_PORT=5432
WEB_PORT=3000
